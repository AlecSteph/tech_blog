{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - Tech Blog{% endblock %}

{% block body %}
    <div class="container">
        <article class="blog-post">
            <header class="mb-4">
                <h1 class="blog-post-title">{{ post.title }}</h1>
                <div class="blog-post-meta text-muted">
                    {% for category in post.categories %}
                        <span class="badge bg-secondary me-1">{{ category.name }}</span>
                    {% endfor %}
                </div>
            </header>
            
            <div class="blog-post-content">
                <p>{{ post.content|nl2br }}</p>
            </div>
            
            <section class="comments mt-5">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h3 class="mb-0">
                        <i class="fas fa-comments me-2"></i>
                        Commentaires 
                        <span class="badge bg-primary ms-2">{{ post.comments|length }}</span>
                    </h3>
                </div>
                
                <div class="comments-list">
                    {% for comment in post.comments %}
                        <div class="comment mb-3 p-3 border rounded">
                            <div class="comment-header d-flex justify-content-between align-items-start">
                                <div class="d-flex align-items-center">
                                    <div class="avatar me-3">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-weight: 600;">
                                            {{ comment.username|first|upper }}
                                        </div>
                                    </div>
                                    <div>
                                        <strong class="comment-author">{{ comment.username }}</strong>
                                        <div class="text-muted small">{{ comment.createAt|date('d/m/Y H:i') }}</div>
                                    </div>
                                </div>
                            </div>
                            <div class="comment-content mt-3 ps-5">
                                {{ comment.content|nl2br }}
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-5 text-muted">
                            <i class="fas fa-comment-slash fa-3x mb-3"></i>
                            <p class="mb-0">Soyez le premier à commenter cet article !</p>
                        </div>
                    {% endfor %}
                </div>
                
                <div class="add-comment mt-4">
                    <h4 class="mb-4">
                        <i class="fas fa-edit me-2"></i>
                        Laisser un commentaire
                    </h4>
                    {{ form_start(form, {'attr': {'class': 'comment-form'}}) }}
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.username, 'Votre nom', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                                {{ form_widget(form.username, {'attr': {'class': 'form-control', 'placeholder': 'Entrez votre nom'}}) }}
                                {{ form_errors(form.username) }}
                            </div>
                        </div>
                        <div class="mb-3">
                            {{ form_label(form.content, 'Votre commentaire', {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Partagez vos pensées...'}}) }}
                            {{ form_errors(form.content) }}
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-paper-plane me-2"></i>
                                Envoyer le commentaire
                            </button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </section>
        </article>
        
        <div class="mt-4">
            <a href="{{ path('app_home') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>
                Retour aux articles
            </a>
        </div>
    </div>
{% endblock %}
