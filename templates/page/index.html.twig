{% extends 'base.html.twig' %}

{% block title %}Accueil - Tech Blog{% endblock %}

{% block body %}
    <div class="container">
        <div class="hero-section text-center py-5 mb-5">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="fas fa-laptop-code me-3"></i>
                Tech Blog
            </h1>
            <p class="lead text-secondary mb-4">Découvrez nos derniers articles techniques et tutoriels</p>
        </div>
        
        <div class="row">
            {% for post in posts %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="mb-3">
                                {% for category in post.categories %}
                                    <span class="badge bg-primary me-1">{{ category.name }}</span>
                                {% endfor %}
                            </div>
                            <h5 class="card-title">{{ post.title }}</h5>
                            <p class="card-text flex-grow-1">{{ post.content|slice(0, 150) }}...</p>
                            <div class="mt-auto">
                                <a href="{{ path('app_post_show', {'id': post.id}) }}" class="btn btn-primary w-100">
                                    <i class="fas fa-book-open me-2"></i>
                                    Lire la suite
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <div class="text-center py-5">
                        <i class="fas fa-newspaper fa-4x text-muted mb-3"></i>
                        <h3 class="text-muted">Aucun article trouvé</h3>
                        <p class="text-muted">Revenez bientôt pour découvrir de nouveaux contenus !</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
